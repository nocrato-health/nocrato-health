# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nocrato_health
DB_USER=nocrato
DB_PASSWORD=nocrato_secret
DATABASE_URL=postgresql://nocrato:nocrato_secret@localhost:5432/nocrato_health

# Auth
JWT_SECRET=<use: openssl rand -base64 64>
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=<use: openssl rand -base64 64>
JWT_REFRESH_EXPIRES_IN=30d

# Email
RESEND_API_KEY=re_...

# WhatsApp (Meta Cloud API)
META_APP_ID=
META_APP_SECRET=
META_SYSTEM_USER_TOKEN=
META_WEBHOOK_VERIFY_TOKEN=
META_GRAPH_API_VERSION=v19.0

# AI — usado apenas no módulo agent/
OPENAI_API_KEY=sk-...

# App
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
