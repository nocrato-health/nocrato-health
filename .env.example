# ──────────────────────────────────────────────────────────────────
# Nocrato Health V2 — Variáveis de Ambiente
#
# Copie este arquivo para .env na raiz do monorepo e preencha os valores.
# O arquivo .env é carregado por apps/api/src/config/env.ts (Zod validation).
# Em produção: colocar em /opt/nocrato-health-v2/.env no servidor Hostinger.
# NUNCA commite o .env com valores reais.
# ──────────────────────────────────────────────────────────────────

# ──────────────────────────────────────────
# App
# ──────────────────────────────────────────

# Ambiente de execução: development | production | test
NODE_ENV=production

# ──────────────────────────────────────────
# Admin inicial (apenas para seed:prod)
# ──────────────────────────────────────────

# Email do agency_admin criado pelo seed de produção
ADMIN_EMAIL=pedro@nocrato.com
# Senha forte — mínimo 8 chars. Removível do .env após primeiro login.
# Gerar com: openssl rand -base64 18
ADMIN_PASSWORD=

# Porta do servidor NestJS (padrão: 3000)
PORT=3000

# ──────────────────────────────────────────
# Banco de dados (PostgreSQL 16)
# Em produção (docker-compose), DB_HOST deve ser "postgres" (nome do serviço)
# ──────────────────────────────────────────

# Host do PostgreSQL — em docker-compose prod: "postgres"
DB_HOST=postgres

# Porta padrão do PostgreSQL
DB_PORT=5432

# Nome do banco de dados
DB_NAME=nocrato_health

# Usuário do banco de dados
DB_USER=nocrato

# Senha forte — gerar com: openssl rand -hex 32
DB_PASSWORD=

# ──────────────────────────────────────────
# JWT — Autenticação stateless
# Gerar ambos com: openssl rand -hex 64
# CRÍTICO: nunca reutilizar o mesmo valor para JWT_SECRET e JWT_REFRESH_SECRET
# ──────────────────────────────────────────

# Segredo para assinar access tokens (mínimo 16 chars)
JWT_SECRET=

# Segredo para assinar refresh tokens (mínimo 16 chars, diferente do JWT_SECRET)
JWT_REFRESH_SECRET=

# Tempo de vida do access token (default: 15m)
JWT_EXPIRES_IN=15m

# Tempo de vida do refresh token (default: 7d)
JWT_REFRESH_EXPIRES_IN=7d

# ──────────────────────────────────────────
# Email (Resend)
# Criar conta em https://resend.com → API Keys → Create API Key
# ──────────────────────────────────────────

# API key do Resend — deve começar com "re_"
RESEND_API_KEY=re_

# Endereço remetente dos emails transacionais (convites, notificações)
EMAIL_FROM=noreply@nocrato.com.br

# ──────────────────────────────────────────
# WhatsApp (Evolution API)
# Em produção: evolution roda no mesmo docker-compose, acessível por nome de serviço
# ──────────────────────────────────────────

# URL interna da Evolution API (docker-compose: "http://evolution:8080")
EVOLUTION_API_URL=http://evolution:8080

# API key configurada no serviço Evolution (AUTHENTICATION_API_KEY no compose)
EVOLUTION_API_KEY=

# Token para validar a assinatura dos webhooks recebidos da Evolution API
# Gerar com: openssl rand -hex 32
EVOLUTION_WEBHOOK_TOKEN=

# ──────────────────────────────────────────
# OpenAI — módulo agent/ (gpt-4o-mini)
# Usado exclusivamente pelo agente WhatsApp para orquestrar agendamentos
# Não usado em nenhum outro módulo do backend
# ──────────────────────────────────────────

# API key da OpenAI — deve começar com "sk-"
OPENAI_API_KEY=sk-

# ──────────────────────────────────────────
# Frontend
# Usado pelo backend para montar URLs absolutas em emails e no agente WhatsApp
# ──────────────────────────────────────────

# URL pública do frontend (usada em links de convite, booking tokens e emails)
FRONTEND_URL=https://app.nocrato.com

# ──────────────────────────────────────────
# E2E — Playwright throttler bypass (TD-29)
# Só tem efeito quando NODE_ENV=test. Em dev/prod é ignorado.
# Gerar com: openssl rand -hex 16
# ──────────────────────────────────────────
E2E_THROTTLE_BYPASS_SECRET=

# ──────────────────────────────────────────
# Bugsink — Self-hosted error tracking (LGPD fase 0, item observabilidade)
# Sentry-compatible. Acessado via SSH tunnel em produção.
# ──────────────────────────────────────────

# Django SECRET_KEY do Bugsink — gerar com: openssl rand -base64 50
# Mínimo 50 chars. Nunca commitar. Nunca reutilizar entre ambientes.
BUGSINK_SECRET_KEY=

# Senha do Postgres para o user bugsink (DB separado do nocrato_health)
# Gerar com: openssl rand -hex 24
BUGSINK_DB_PASSWORD=

# Superuser inicial do Bugsink — criado no primeiro boot via CREATE_SUPERUSER
BUGSINK_ADMIN_EMAIL=admin@nocrato.com
# Gerar com: openssl rand -base64 18
BUGSINK_ADMIN_PASSWORD=

# URL base usada pelo Bugsink para gerar links nos emails de notificação.
# Em dev: http://localhost:8000
# Em prod: http://localhost:8000 (acesso só via SSH tunnel — não expor publicamente)
BUGSINK_BASE_URL=http://localhost:8000

# Sentry DSN — preenchido APÓS primeira subida do Bugsink.
# Fluxo: (1) subir Bugsink → (2) logar na UI → (3) criar projeto "nocrato-api"
# → (4) copiar a DSN gerada pra cá → (5) reiniciar a API.
# Em dev: opcional (se vazio, SDK desabilita e não captura nada)
# Em prod: obrigatório — env.ts refine bloqueia o boot se NODE_ENV=production e DSN vazia
SENTRY_DSN=

# ──────────────────────────────────────────
# pgcrypto — criptografia em repouso (LGPD fase 0)
# Usada para patients.document, clinical_notes.content e outros dados sensíveis.
# ──────────────────────────────────────────

# Chave simétrica AES-256 usada pelo pgp_sym_encrypt/decrypt do pgcrypto.
# Gerar com: openssl rand -hex 32
#
# ⚠️  CRÍTICO: se esta chave for perdida, TODOS os dados criptografados
#    (documentos de pacientes, notas clínicas) ficam permanentemente
#    inacessíveis. Backup obrigatório em local separado do VPS.
#
# Rotação: não suportada no MVP. Para rotacionar, seria necessário
# re-encriptar todos os registros — fica como débito pós-escala.
DOCUMENT_ENCRYPTION_KEY=
